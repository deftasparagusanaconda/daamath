echo step 2: generate code

echo cd to generators/
cd generators/

echo generating unicode/*.py
python 'generate unicode.py'

#echo generating functions/*.py
#python 'generate functions.py'

#echo generating context.py
#python 'generate context.py'

echo generating constants/*.py
python 'generate constants.py'

echo fixing implementation quirks
./quirk_fixer

echo cd back to ../
cd ../
